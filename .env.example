# Copy to .env before running docker compose (e.g. copy .env.example .env on Windows).
# Optional: set IBM_QUANTUM_TOKEN if you use IBM Quantum in the app or Jupyter.
IBM_QUANTUM_TOKEN=

# Full stack (docker-compose.full.yml): optional overrides; defaults work for local dev.
INFLUX_TOKEN=qasic-telemetry-token
GRAFANA_ADMIN_PASSWORD=admin
